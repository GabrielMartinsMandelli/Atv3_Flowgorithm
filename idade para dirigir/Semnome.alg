algoritmo "Comissão"
// Autor : Gabriel martins
// Data : 13/04/2026

var
//variavel
  idade:real
inicio
// Seção de Comandos
   escreva("Informe a sua idade:")
   leia(idade)


   se idade <= 17 entao
   escreval("voce nao pode dirigir")
   leia(idade)
   senao
   escreval("voce pode dirigir")
   leia(idade)
   fimse
fimalgoritmo

