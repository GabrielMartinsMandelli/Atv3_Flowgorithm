algoritmo "senha"
// Autor : Gabriel martins
// Data : 13/04/2026

var
//variavel
  senha:literal
inicio
// Seçăo de Comandos
   escreva("Informe a sua senha:")
   leia(senha)


   se senha = "acb23" entao
   escreval("senha correta")
   leia(senha)
   senao
   escreval("senha incorreta")
   leia(senha)
   fimse
fimalgoritmo
